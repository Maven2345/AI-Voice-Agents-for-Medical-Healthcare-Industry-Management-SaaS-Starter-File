NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

OPENAI_API_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# OPTIONAL: Business ID for the live demo widget on the landing page
# Leave empty to hide the widget entirely. Fill in when you want to enable it.
NEXT_PUBLIC_DEMO_BUSINESS_ID=

OPENAI_REALTIME_MODEL=gpt-realtime

NEXT_PUBLIC_ENABLE_VOICE=true

# Resend — get your key at https://resend.com/api-keys
RESEND_API_KEY=
# Resend's shared sender — works without domain verification for local testing
RESEND_FROM_EMAIL=onboarding@resend.dev
# Redirect ALL outgoing emails to your inbox during local dev
RESEND_DEV_OVERRIDE_TO=

# ── Website Builder ────────────────────────────────────────────────────────────
# Wallet that receives USDC subscription payments
NEXT_PUBLIC_WEBSITE_BUILDER_WALLET=
# Monthly price in USDC (change here to update price everywhere)
NEXT_PUBLIC_WEBSITE_BUILDER_PRICE_USDC=1
# USDC contract on Polygon mainnet
NEXT_PUBLIC_USDC_CONTRACT_POLYGON=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359
# Polygon chain ID (137 = mainnet, 80002 = amoy testnet)
NEXT_PUBLIC_POLYGON_CHAIN_ID=137
